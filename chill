#!/usr/bin/env bash
# ChillBTC — wrapper pour lancer le CLI d'exploitation mensuelle depuis la racine.
# Usage : ./chill
set -e
ENGINE="$(dirname "$0")/engine"
# iCloud re-applique périodiquement le flag 'hidden' sur le venv, ce qui fait
# que Python ignore les .pth et n'arrive plus à charger chillbtc.
# On dé-hide avant chaque lancement (< 1 s, transparent).
chflags -R nohidden "$ENGINE/.venv" 2>/dev/null || true
cd "$ENGINE" && exec uv run chillbtc "$@"
